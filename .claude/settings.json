{
  "permissions": {
    "allow": [
      "Bash(python -m py_compile:*)",
      "Bash(grep -n *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/block_sensitive.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/pii_guard.py"
          }
        ]
      }
    ]
  }
}
